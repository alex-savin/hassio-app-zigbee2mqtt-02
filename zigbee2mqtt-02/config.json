{
  "name": "Zigbee2MQTT Instance 02",
  "version": "2.10.0-1",
  "slug": "zigbee2mqtt-02",
  "description": "Use your ZigBee devices without the vendor's bridge or gateway (Instance 02)",
  "breaking_versions": [
    "2.0.0-1"
  ],
  "uart": true,
  "udev": true,
  "url": "https://github.com/alex-savin/hassio-app-zigbee2mqtt-02",
  "startup": "application",
  "services": [
    "mqtt:need"
  ],
  "hassio_api": true,
  "arch": [
    "amd64"
  ],
  "boot": "auto",
  "init": false,
  "ingress": true,
  "ingress_port": 8092,
  "ingress_protocol": "http",
  "timeout": 30,
  "panel_icon": "mdi:zigbee",
  "map": [
    {
      "type": "share",
      "read_only": false
    },
    {
      "type": "homeassistant_config",
      "read_only": false,
      "path": "/config"
    },
    {
      "type": "addon_config",
      "read_only": false,
      "path": "/addon_config"
    }
  ],
  "ports": {
    "8487/tcp": 8487,
    "8092/tcp": null
  },
  "ports_description": {
    "8487/tcp": "Socat tcp-listen port (host: 8487)",
    "8092/tcp": "Frontend tcp-listen port"
  },
  "options": {
    "data_path": "/config/zigbee2mqtt-02",
    "socat": {
      "enabled": false,
      "master": "pty,raw,echo=0,link=/tmp/ttyZ2M,mode=777",
      "slave": "tcp-listen:8487,keepalive,nodelay,reuseaddr,keepidle=1,keepintvl=1,keepcnt=5",
      "options": "-d -d",
      "log": false
    },
    "mqtt": {},
    "serial": {}
  },
  "schema": {
    "data_path": "str",
    "socat": {
      "enabled": "bool?",
      "master": "str?",
      "slave": "str?",
      "options": "str?",
      "log": "bool?"
    },
    "mqtt": {
      "server": "str?",
      "ca": "str?",
      "key": "str?",
      "cert": "str?",
      "user": "str?",
      "password": "str?",
      "base_topic": "str?"
    },
    "serial": {
      "port": "str?",
      "adapter": "match(zstack|deconz|zigate|ezsp|ember|zboss)?",
      "baudrate": "int?",
      "rtscts": "bool?"
    },
    "watchdog": "str?",
    "force_onboarding": "bool?"
  },
  "image": "ghcr.io/alex-savin/zigbee2mqtt-02-{arch}"
}
